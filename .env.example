# Copy to .env.local and fill in real values. Never commit .env.local.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# public site origin — ใช้สร้าง sitemap.xml / robots.txt (ไม่มี trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-domain.example.com

# server-only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@<host>:5432/postgres

# cron protection (Phase 8) — Vercel Cron จะแนบ Authorization: Bearer <CRON_SECRET>
# ให้อัตโนมัติเมื่อมี env นี้ในโปรเจกต์ (endpoint /api/cron/* ตรวจค่านี้)
CRON_SECRET=<random-secret>
